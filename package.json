{
  "name": "echoes-vault-opencode",
  "version": "1.2.0",
  "description": "EchoesVault — persistent memory plugin for OpenCode. Obsidian-style knowledge base with daily logs, encyclopedia pages, and session resumption.",
  "type": "module",
  "main": "index.ts",
  "exports": {
    "./server": {
      "import": "./index.ts",
      "types": "./index.ts"
    },
    "./tui": {
      "import": "./tui.tsx",
      "types": "./tui.tsx"
    }
  },
  "files": [
    "index.ts",
    "tui.tsx"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "memory",
    "knowledge-base",
    "obsidian",
    "vault"
  ],
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": ">=1.16.0",
    "@opentui/solid": ">=0.4.3",
    "solid-js": ">=1.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/psinetron/echoes-vault-opencode.git"
  }
}
